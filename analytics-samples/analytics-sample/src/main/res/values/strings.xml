  <string name="sample_title">Freshpaint Android SDK sample</string>
  <string name="sample_subtitle">A single app to validate the SDK end to end: initialization, automatic events, attribution capture, identity APIs, custom tracking, and operational controls.</string>
  <string name="sample_setup_title">Initialize the SDK</string>
  <string name="sample_setup_body">Configure a write key with `freshpaint.sample.writeKey` in `local.properties` or with the `FRESHPAINT_SAMPLE_WRITE_KEY` environment variable. On startup, the sample enables lifecycle events, screen tracking, attribution collection, and deep-link handling.</string>
  <string name="sample_mmp_title">Attribution and deep links</string>
  <string name="sample_mmp_body">Use the demo deep link to exercise campaign-style attribution. The sample shows how click IDs and UTM parameters are captured, how `Deep Link Opened` is tracked, and how attribution data can enrich first-open install flows.</string>
  <string name="sample_event_title">Identity and event APIs</string>
  <string name="sample_event_body">Trigger representative SDK calls for identify, group, alias, screen, purchase, flush, and reset so this sample works as both a visual demo and an integration reference.</string>
  <string name="sample_identity_title">Identity and screen APIs</string>
  <string name="sample_identity_body">Work with user profiles, group membership, aliasing, and screen calls using realistic sample data.</string>
  <string name="sample_custom_title">Custom events and operations</string>
  <string name="sample_custom_body">Send a custom event, test a purchase-style event, flush the queue, or reset the current identity from one place.</string>

