<resources xmlns:tools="http://schemas.android.com/tools">

  <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
    <item name="colorPrimary">@color/sample_primary</item>
    <item name="colorPrimaryVariant">@color/sample_primary_dark</item>
    <item name="colorSecondary">@color/sample_accent</item>
    <item name="colorSurface">@color/sample_surface</item>
    <item name="android:windowBackground">@color/sample_background</item>
    <item name="android:statusBarColor">@color/sample_primary_dark</item>
    <item name="materialButtonStyle">@style/AppTheme.Widget.Button</item>
    <item name="textInputStyle">@style/AppTheme.Widget.TextInputLayout</item>
    <item name="android:textViewStyle">@style/AppTheme.Widget.TextView</item>
  </style>

  <style name="AppTheme.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
    <item name="titleTextColor">@android:color/white</item>
    <item name="android:textColorPrimary">@android:color/white</item>
    <item name="subtitleTextColor">#D5E6F8</item>
    <item name="android:textColorSecondary">#D5E6F8</item>
    <item name="android:elevation">0dp</item>
  </style>

  <style name="AppTheme.Widget.Button" parent="Widget.MaterialComponents.Button">
    <item name="android:minHeight">48dp</item>
    <item name="cornerRadius">14dp</item>
    <item name="android:textAllCaps">false</item>
  </style>

  <style name="AppTheme.Widget.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
    <item name="boxBackgroundMode">outline</item>
    <item name="boxCornerRadiusTopStart">16dp</item>
    <item name="boxCornerRadiusTopEnd">16dp</item>
    <item name="boxCornerRadiusBottomEnd">16dp</item>
    <item name="boxCornerRadiusBottomStart">16dp</item>
  </style>

  <!-- This is an parent for AppTheme.Widget.TextView. It's empty, but it is definitely used. -->
  <style name="AppTheme.Widget" tools:ignore="UnusedResources"/>

  <style name="AppTheme.Widget.TextView" parent="android:Widget.TextView">
    <item name="android:textColor">@color/sample_text_primary</item>
  </style>

  <style name="AppTheme.Widget.Card" parent="Widget.MaterialComponents.CardView">
    <item name="cardUseCompatPadding">true</item>
    <item name="cardCornerRadius">20dp</item>
    <item name="cardBackgroundColor">@color/sample_surface</item>
    <item name="strokeColor">@color/sample_outline</item>
    <item name="strokeWidth">1dp</item>
  </style>

  <style name="AppTheme.Widget.OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
    <item name="strokeColor">@color/sample_outline_strong</item>
    <item name="android:textColor">@color/sample_primary</item>
  </style>

</resources>
